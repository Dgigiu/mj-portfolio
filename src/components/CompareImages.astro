---
import { Image, getImage } from "astro:assets";

interface Props {
  left: ImageMetadata;
  leftAlt: string;
  leftCaption?: string;
  right: ImageMetadata;
  rightAlt: string;
  rightCaption?: string;
}

const { left, leftAlt, leftCaption, right, rightAlt, rightCaption } = Astro.props;

const leftZoom = await getImage({ src: left, format: "webp" });
const rightZoom = await getImage({ src: right, format: "webp" });
---

<div class="compare">
  <figure>
    <button
      type="button"
      class="frame zoomable"
      data-zoom-src={leftZoom.src}
      data-zoom-alt={leftAlt}
      data-zoom-caption={leftCaption ?? ""}
      aria-label={`Zoom image${leftAlt ? ": " + leftAlt : ""}`}
    >
      <Image src={left} alt={leftAlt} widths={[400, 800]} sizes="(min-width: 720px) 50vw, 100vw" loading="lazy" />
    </button>
    {leftCaption && <figcaption>{leftCaption}</figcaption>}
  </figure>
  <figure>
    <button
      type="button"
      class="frame zoomable"
      data-zoom-src={rightZoom.src}
      data-zoom-alt={rightAlt}
      data-zoom-caption={rightCaption ?? ""}
      aria-label={`Zoom image${rightAlt ? ": " + rightAlt : ""}`}
    >
      <Image src={right} alt={rightAlt} widths={[400, 800]} sizes="(min-width: 720px) 50vw, 100vw" loading="lazy" />
    </button>
    {rightCaption && <figcaption>{rightCaption}</figcaption>}
  </figure>
</div>

<style>
  .compare {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
    margin: var(--space-6) 0;
  }

  figure {
    margin: 0;
  }

  .frame {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .frame.zoomable {
    display: block;
    width: 100%;
    padding: 0;
    margin: 0;
    color: inherit;
    cursor: zoom-in;
    transition: box-shadow var(--transition-base);
  }

  .frame.zoomable:hover {
    box-shadow: var(--shadow-md);
  }

  .frame.zoomable:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }

  .frame :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  figcaption {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--fg-tertiary);
    margin-top: var(--space-3);
    line-height: var(--leading-normal);
  }

  @media (max-width: 640px) {
    .compare {
      grid-template-columns: 1fr;
    }
  }

</style>
