---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="meta">© {year} Miguel Jesus · Designing with clarity and calm purpose since 2005.</p>
    <div class="social">
      <a
        href="https://www.linkedin.com/in/migueljss/"
        target="_blank"
        rel="me noopener noreferrer"
        class="social-link"
      >LinkedIn</a>
      <a
        href="mailto:miguel.jss@gmail.com?subject=Hello%20from%20migueljss.com"
        class="social-link"
      >Email</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: var(--hairline) solid var(--border-subtle);
    margin-top: var(--space-24);
    padding: var(--space-8) 0;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: space-between;
    align-items: center;
  }

  .meta {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    line-height: var(--leading-normal);
    color: var(--fg-tertiary);
    margin: 0;
  }

  .social {
    display: flex;
    gap: var(--space-4);
  }

  .social-link {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--fg-tertiary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .social-link:hover {
    color: var(--fg-primary);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
  }
</style>
