---
import { Image } from "astro:assets";

interface Props {
  href: string;
  title: string;
  summary: string;
  client?: string;
  domain?: string;
  period?: string;
  cover?: ImageMetadata;
  compact?: boolean;
}

const { href, title, summary, client, domain, period, cover, compact = false } = Astro.props;

const metaParts = compact
  ? [client].filter(Boolean)
  : [client, domain, period].filter(Boolean);
---

<a href={href} class:list={["card", { compact }]}>
  <div class="card-media">
    {
      cover ? (
        <Image
          src={cover}
          alt=""
          widths={[480, 800, 1200]}
          sizes="(min-width: 720px) 50vw, 100vw"
        />
      ) : (
        <div class="card-placeholder" aria-hidden="true">
          <span>{title}</span>
        </div>
      )
    }
  </div>
  <div class="card-body">
    {metaParts.length > 0 && <p class="card-meta">{metaParts.join(" · ")}</p>}
    <h3 class="card-title">{title}</h3>
    {!compact && <p class="card-summary">{summary}</p>}
    {!compact && <span class="card-cta" aria-hidden="true">Read the case study →</span>}
  </div>
</a>

<style>
  .card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-8);
    align-items: center;
    text-decoration: none;
    color: var(--fg-primary);
  }

  .card:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
    border-radius: var(--radius-sm);
  }

  .card-media {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-subtle);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--duration-normal) var(--ease-out);
  }

  .card:hover .card-media {
    box-shadow: var(--shadow-md);
  }

  .card-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-weight: var(--weight-semi);
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-snug);
    padding: var(--space-5);
    text-align: center;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .card-meta {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    line-height: var(--leading-normal);
    color: var(--fg-muted);
    margin: 0;
  }

  .card-title {
    font-family: var(--font-sans);
    font-weight: var(--weight-semi);
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-snug);
    color: var(--fg-primary);
    margin: 0;
  }

  .card-summary {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--fg-secondary);
    margin: 0;
  }

  .card-cta {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--accent);
    margin-top: var(--space-2);
  }

  /* Compact (image-on-top, vertical) variant for "More case studies" */
  .card.compact {
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .card.compact .card-media {
    aspect-ratio: 16 / 10;
  }

  .card.compact .card-title {
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-normal);
  }

  @media (max-width: 720px) {
    .card:not(.compact) {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card-media {
      transition: none;
    }
  }
</style>
