---
const base = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
const path = Astro.url.pathname;
const norm = (p: string) => (p.endsWith("/") ? p : p + "/");

const isActive = (href: string) => {
  if (href === base) return norm(path) === norm(base);
  return path.startsWith(href);
};

const links = [
  { href: base, label: "Work" },
  { href: `${base}about/`, label: "About" },
  { href: `${base}contact/`, label: "Contact" },
];
---

<header class="nav">
  <div class="container nav-inner">
    <a href={base} class="brand" aria-label="Miguel Jesus, home">
      <span class="brand-mark">MJ</span>
      <span class="brand-name">Miguel Jesus</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={["nav-link", { "is-active": isActive(link.href) }]}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav {
    padding: var(--space-5) 0;
    position: sticky;
    top: 0;
    background: rgba(240, 240, 240, 0.86);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    z-index: 10;
    border-bottom: 1px solid transparent;
    box-shadow: 0 0 0 rgba(14, 14, 16, 0);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .nav.is-scrolled {
    border-bottom-color: var(--border);
    box-shadow: 0 6px 16px rgba(14, 14, 16, 0.04);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--text);
  }

  .brand:hover,
  .brand:focus-visible {
    color: var(--text);
  }

  .brand-mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-md);
    letter-spacing: -0.02em;
    background: var(--text);
    color: var(--bg);
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
  }

  .brand-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-base);
    letter-spacing: -0.005em;
  }

  nav ul {
    display: flex;
    gap: var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav-link {
    color: var(--text-soft);
    text-decoration: none;
    font-size: var(--text-sm);
    letter-spacing: 0.005em;
    padding: var(--space-1) 0;
    border-bottom: 1px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  .nav-link.is-active {
    color: var(--text);
  }

  @media (max-width: 480px) {
    .brand-name {
      display: none;
    }
  }
</style>

<script>
  const nav = document.querySelector(".nav");
  if (nav) {
    const update = () => {
      nav.classList.toggle("is-scrolled", window.scrollY > 4);
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
  }
</script>
