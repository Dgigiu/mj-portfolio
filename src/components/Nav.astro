---
const base = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
const path = Astro.url.pathname;
const norm = (p: string) => (p.endsWith("/") ? p : p + "/");

const isActive = (href: string) => {
  if (href === base) return norm(path) === norm(base);
  return path.startsWith(href);
};

const links = [
  { href: base, label: "Work" },
  { href: `${base}about/`, label: "About" },
  { href: `${base}contact/`, label: "Contact" },
];
---

<header class="nav">
  <div class="container nav-inner">
    <a href={base} class="brand" aria-label="Miguel Jesus, home">Miguel Jesus</a>
    <nav aria-label="Primary">
      <ul>
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={["nav-link", { "is-active": isActive(link.href) }]}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav {
    padding: var(--space-6) 0;
    position: sticky;
    top: 0;
    background: var(--bg-canvas);
    z-index: 10;
    border-bottom: var(--hairline) solid var(--border-subtle);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .brand {
    font-family: var(--font-sans);
    font-weight: var(--weight-semi);
    font-size: var(--text-md);
    letter-spacing: var(--tracking-snug);
    text-decoration: none;
    color: var(--fg-primary);
  }

  nav ul {
    display: flex;
    gap: var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--fg-secondary);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: var(--rule-bold) solid transparent;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--fg-primary);
  }

  .nav-link.is-active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 480px) {
    nav ul {
      gap: var(--space-4);
    }
  }
</style>
