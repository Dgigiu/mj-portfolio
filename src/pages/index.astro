---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import CaseStudyCard from "../components/CaseStudyCard.astro";
import portrait from "../assets/brand/miguel-portrait-color.png";

const studies = (await getCollection("case-studies", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const base = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
---

<BaseLayout title="Miguel Jesus" description="Senior Product Designer in Porto. Case studies across B2B SaaS and mobile products.">
  <section class="hero" aria-labelledby="hero-title">
    <Image
      src={portrait}
      alt=""
      aria-hidden="true"
      class="hero-portrait"
      loading="eager"
      widths={[480, 720, 960, 1200]}
      sizes="min(60vw, 720px)"
    />
    <div class="hero-vignette" aria-hidden="true"></div>
    <div class="hero-hairline" aria-hidden="true"></div>

    <div class="container hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">Portfolio · 2026</p>
        <h1 id="hero-title">Calm products for complex work.</h1>
        <p class="hero-subtitle">
          I'm Miguel. For 20+ years I've designed SaaS and mobile products with small teams, often as the only designer in the room. The case studies below are stories about taking something messy and making it usable.
        </p>
        <p class="hero-meta">
          <span>Porto</span>
          <span aria-hidden="true">·</span>
          <span>Open to senior in-house roles, remote or hybrid</span>
          <span aria-hidden="true">·</span>
          <a href="mailto:miguel.jss@gmail.com?subject=Hello%20from%20migueljss.com">miguel.jss@gmail.com</a>
        </p>
      </div>
    </div>

    <a href="#work" class="hero-scroll" aria-label="Jump to selected work">
      <span>Selected work</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" aria-hidden="true">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </a>
  </section>

  <section id="work" class="work container">
    <header class="work-head">
      <h2>Selected work</h2>
      <span class="work-count mj-caption">{studies.length} case {studies.length === 1 ? "study" : "studies"}</span>
    </header>
    <ul class="card-list">
      {
        studies.map((s) => (
          <li>
            <CaseStudyCard
              href={`${base}work/${s.slug}/`}
              title={s.data.title}
              summary={s.data.summary}
              client={s.data.client}
              domain={s.data.domain}
              period={s.data.period}
              cover={s.data.cover}
            />
          </li>
        ))
      }
    </ul>
  </section>

  <section class="outro container">
    <div class="outro-inner">
      <h2>Get in touch</h2>
      <p>
        I'm open to senior in-house product design roles. The fastest way to reach me is{" "}
        <a href="mailto:miguel.jss@gmail.com?subject=Hello%20from%20migueljss.com">miguel.jss@gmail.com</a>, or find me on{" "}
        <a href="https://www.linkedin.com/in/migueljss/" target="_blank" rel="me noopener noreferrer">LinkedIn</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: min(720px, 88vh);
    background: var(--accent);
    color: #fff;
    overflow: hidden;
    isolation: isolate;
    display: flex;
    align-items: center;
  }

  /* Color portrait on cobalt — clean cutout (transparent bg), portrait
     orientation (3072×3821, ~0.80 aspect). Anchored bottom-right at the
     section's natural height; cobalt shows through the transparent area
     around Miguel. No blend mode or filter — color reads naturally. */
  .hero-portrait {
    position: absolute;
    right: 0;
    bottom: 0;
    height: 100%;
    width: auto;
    max-width: none;
    z-index: 1;
    pointer-events: none;
    user-select: none;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      130% 100% at 0% 0%,
      rgba(8, 14, 32, 0.88) 0%,
      rgba(8, 14, 32, 0.6) 38%,
      rgba(8, 14, 32, 0) 70%
    );
    z-index: 2;
    pointer-events: none;
  }

  .hero-hairline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.18);
    z-index: 3;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    padding-top: var(--space-24);
    padding-bottom: var(--space-20);
    max-width: var(--content-page);
  }

  /* Hard cap on the text column so it never bleeds into the portrait area. */
  .hero-content {
    max-width: 560px;
  }

  .hero-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    font-weight: var(--weight-medium);
    color: rgba(255, 255, 255, 0.78);
    margin: 0 0 var(--space-6);
  }

  .hero h1 {
    font-family: var(--font-sans);
    font-weight: var(--weight-bold);
    font-size: clamp(44px, 6vw, 80px);
    line-height: 1;
    letter-spacing: -0.035em;
    color: #fff;
    text-wrap: balance;
    margin: 0 0 var(--space-6);
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.92);
    max-width: 520px;
    margin: 0 0 var(--space-8);
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 12px;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.78);
    margin: 0;
  }

  .hero-meta a {
    color: #fff;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.55);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--duration-fast) var(--ease-out);
  }

  .hero-meta a:hover {
    text-decoration-color: #fff;
  }

  .hero-scroll {
    position: absolute;
    left: 50%;
    bottom: var(--space-6);
    transform: translateX(-50%);
    z-index: 5;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--font-sans);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-xs);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .hero-scroll:hover {
    color: #fff;
  }

  /* Laptop / tablet: extend the vignette so the text column stays legible
     where it overlaps the photo's left fade. */
  @media (max-width: 1100px) {
    .hero-vignette {
      background: radial-gradient(
        150% 110% at 0% 0%,
        rgba(8, 14, 32, 0.9) 0%,
        rgba(8, 14, 32, 0.7) 42%,
        rgba(8, 14, 32, 0.25) 75%,
        rgba(8, 14, 32, 0) 100%
      );
    }

    .hero-inner {
      padding-top: var(--space-20);
    }
  }

  @media (max-width: 720px) {
    .hero {
      min-height: 600px;
    }

    .hero-portrait {
      opacity: 0.55;
    }

    .hero-vignette {
      background: radial-gradient(
        160% 130% at 0% 0%,
        rgba(8, 14, 32, 0.92) 0%,
        rgba(8, 14, 32, 0.78) 50%,
        rgba(8, 14, 32, 0.35) 85%,
        rgba(8, 14, 32, 0) 100%
      );
    }

    .hero-inner {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* Work index */
  .work {
    scroll-margin-top: var(--space-6);
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
  }

  .work-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-5);
    padding-bottom: var(--space-6);
    border-bottom: var(--hairline) solid var(--border-subtle);
    margin-bottom: var(--space-8);
  }

  .work-head h2 {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-snug);
  }

  .work-count {
    flex-shrink: 0;
  }

  .card-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  /* Outro */
  .outro {
    padding-bottom: var(--space-16);
  }

  .outro-inner {
    max-width: var(--content-narrow);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-12);
    border-top: var(--hairline) solid var(--border-subtle);
  }

  .outro-inner h2 {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-snug);
  }

  .outro-inner p {
    color: var(--fg-secondary);
  }
</style>
