---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import CaseStudyCard from "../components/CaseStudyCard.astro";
import portrait from "../assets/brand/miguel-portrait-color-wide.png";

const studies = (await getCollection("case-studies", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const base = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
---

<BaseLayout title="Miguel Jesus" description="Senior Product Designer in Porto. Case studies across B2B SaaS and mobile products.">
  <section class="hero" aria-labelledby="hero-title">
    <Image
      src={portrait}
      alt=""
      aria-hidden="true"
      class="hero-portrait"
      loading="eager"
      widths={[720, 1080, 1440, 1920]}
      sizes="1400px"
    />
    <div class="hero-vignette" aria-hidden="true"></div>
    <div class="hero-hairline" aria-hidden="true"></div>

    <div class="container hero-inner">
      <div class="hero-content">
        <h1 id="hero-title">Calm products for complex work.</h1>
        <p class="hero-subtitle">
          I'm Miguel. For 20+ years I've designed SaaS and mobile products with small teams, often as the only designer in the room. The case studies below are stories about taking something messy and making it usable.
        </p>
        <a href="#work" class="hero-scroll" aria-label="Jump to selected work">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section id="work" class="work container">
    <header class="work-head">
      <h2>Selected work</h2>
      <span class="work-count mj-caption">{studies.length} case {studies.length === 1 ? "study" : "studies"}</span>
    </header>
    <ul class="card-list">
      {
        studies.map((s) => (
          <li>
            <CaseStudyCard
              href={`${base}work/${s.slug}/`}
              title={s.data.title}
              summary={s.data.summary}
              client={s.data.client}
              domain={s.data.domain}
              period={s.data.period}
              cover={s.data.cover}
            />
          </li>
        ))
      }
    </ul>
  </section>

  <section class="outro container">
    <div class="outro-inner">
      <h2>Get in touch</h2>
      <p>
        I'm open to senior in-house product design roles. The fastest way to reach me is{" "}
        <a href="mailto:miguel.jss@gmail.com?subject=Hello%20from%20migueljss.com">miguel.jss@gmail.com</a>, or find me on{" "}
        <a href="https://www.linkedin.com/in/migueljss/" target="_blank" rel="me noopener noreferrer">LinkedIn</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: min(720px, 88vh);
    background: var(--accent);
    color: #fff;
    overflow: hidden;
    isolation: isolate;
    display: flex;
    align-items: center;
  }

  /* Color cutout portrait, anchored bottom-right and sized by the panel
     height so it always fills the cobalt area regardless of the text
     column. The figure sits on the right; the vignette below darkens the
     top-left so the heading stays readable where the photo bleeds under it.
     Right anchor freezes at 1440 (where the composition reads best) and
     centers beyond that, so the figure stops drifting toward the edge on
     wide screens instead of hugging the viewport's right side. */
  /* On wide viewports the portrait sits ABOVE the vignette so the figure
     keeps its full color. The portrait is a transparent cutout, so the
     vignette still darkens the cobalt under the text column where the
     image is transparent. At narrower widths the text overlaps the
     figure body and that dim-the-figure behavior is restored below. */
  .hero-portrait {
    position: absolute;
    right: max(0px, calc((100% - 1440px) / 2));
    bottom: 0;
    height: 100%;
    width: auto;
    max-width: none;
    z-index: 2;
    pointer-events: none;
    user-select: none;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      130% 100% at 0% 0%,
      rgba(8, 14, 32, 0.88) 0%,
      rgba(8, 14, 32, 0.6) 38%,
      rgba(8, 14, 32, 0) 70%
    );
    z-index: 1;
    pointer-events: none;
  }

  .hero-hairline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.18);
    z-index: 3;
  }

  .hero-inner {
    position: relative;
    z-index: 4;
    padding-top: var(--space-24);
    padding-bottom: var(--space-20);
  }

  /* Hard cap on the text column so it never bleeds into the portrait area. */
  .hero-content {
    max-width: 560px;
  }

  .hero h1 {
    font-family: var(--font-sans);
    font-weight: var(--weight-bold);
    font-size: clamp(44px, 6vw, 80px);
    line-height: 1;
    letter-spacing: -0.035em;
    color: #fff;
    text-wrap: balance;
    margin: 0 0 var(--space-6);
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.92);
    max-width: 520px;
    margin: 0 0 var(--space-8);
  }

  .hero-scroll {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    margin-top: var(--space-2);
    margin-left: -10px;
    transition: color var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
  }

  .hero-scroll:hover {
    color: #fff;
    transform: translateY(2px);
  }

  /* Laptop / tablet: extend the vignette so the text column stays legible
     where it overlaps the photo's left fade. Restore vignette-above-portrait
     so the figure dims and recedes behind text at these widths. */
  @media (max-width: 1100px) {
    .hero-portrait {
      z-index: 1;
    }

    .hero-vignette {
      z-index: 2;
      background: radial-gradient(
        150% 110% at 0% 0%,
        rgba(8, 14, 32, 0.9) 0%,
        rgba(8, 14, 32, 0.7) 42%,
        rgba(8, 14, 32, 0.25) 75%,
        rgba(8, 14, 32, 0) 100%
      );
    }

    .hero-inner {
      padding-top: var(--space-20);
    }
  }

  @media (max-width: 720px) {
    .hero {
      min-height: 600px;
    }

    /* Push the figure into the right half of the viewport on phones.
       The source has the figure roughly centered, so a right:0 anchor
       leaves the face sitting near horizontal center. A fixed-pixel
       shift past the right edge keeps the figure consistently anchored
       to the right across 360–414px phone widths (the image width is
       driven by the panel height, not the viewport, so a % shift would
       vary the framing). */
    .hero-portrait {
      right: -220px;
      opacity: 0.55;
    }

    .hero-vignette {
      background: radial-gradient(
        160% 130% at 0% 0%,
        rgba(8, 14, 32, 0.92) 0%,
        rgba(8, 14, 32, 0.78) 50%,
        rgba(8, 14, 32, 0.35) 85%,
        rgba(8, 14, 32, 0) 100%
      );
    }

    .hero-inner {
      padding-top: var(--space-16);
      padding-bottom: var(--space-16);
    }
  }

  /* Work index */
  .work {
    scroll-margin-top: var(--space-6);
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
  }

  .work-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-5);
    padding-bottom: var(--space-6);
    border-bottom: var(--hairline) solid var(--border-subtle);
    margin-bottom: var(--space-8);
  }

  .work-head h2 {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-snug);
  }

  .work-count {
    flex-shrink: 0;
  }

  .card-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  /* Outro */
  .outro {
    padding-bottom: var(--space-16);
  }

  .outro-inner {
    max-width: var(--content-narrow);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-12);
    border-top: var(--hairline) solid var(--border-subtle);
  }

  .outro-inner h2 {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-snug);
  }

  .outro-inner p {
    color: var(--fg-secondary);
  }
</style>
