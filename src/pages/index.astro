---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CaseStudyCard from "../components/CaseStudyCard.astro";

const studies = (await getCollection("case-studies", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const base = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
---

<BaseLayout title="Miguel Jesus" description="Senior Product Designer in Porto. Case studies across B2B SaaS and mobile products.">
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <p class="mj-eyebrow">SENIOR PRODUCT DESIGNER · PORTO</p>
        <h1>Calm products for complex work.</h1>
        <p class="intro">
          I'm Miguel. For 20+ years I've designed SaaS and mobile products with small teams, often as the only designer in the room. Below are a few case studies. Each is a story about taking something messy and making it usable.
        </p>
      </div>
    </div>
  </section>

  <section class="work container">
    <header class="work-head">
      <h2>Selected work</h2>
      <span class="work-count mj-caption">{studies.length} case {studies.length === 1 ? "study" : "studies"}</span>
    </header>
    <ul class="card-list">
      {
        studies.map((s) => (
          <li>
            <CaseStudyCard
              href={`${base}work/${s.slug}/`}
              title={s.data.title}
              summary={s.data.summary}
              client={s.data.client}
              domain={s.data.domain}
              period={s.data.period}
              cover={s.data.cover}
            />
          </li>
        ))
      }
    </ul>
  </section>

  <section class="outro container">
    <div class="outro-inner">
      <h2>Get in touch</h2>
      <p>
        I'm open to senior in-house product design roles. The fastest way to reach me is{" "}
        <a href="mailto:miguel.jss@gmail.com?subject=Hello%20from%20migueljss.com">miguel.jss@gmail.com</a>, or find me on{" "}
        <a href="https://www.linkedin.com/in/migueljss/" target="_blank" rel="me noopener noreferrer">LinkedIn</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-24) 0 var(--space-16);
  }

  .hero-inner {
    max-width: var(--content-narrow);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .hero-inner h1 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
  }

  .intro {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--fg-secondary);
    margin: 0;
  }

  .work {
    padding-bottom: var(--space-16);
  }

  .work-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-5);
    padding-bottom: var(--space-6);
    border-bottom: var(--hairline) solid var(--border-subtle);
    margin-bottom: var(--space-8);
  }

  .work-head h2 {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-snug);
  }

  .work-count {
    flex-shrink: 0;
  }

  .card-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .outro {
    padding-bottom: var(--space-16);
  }

  .outro-inner {
    max-width: var(--content-narrow);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-12);
    border-top: var(--hairline) solid var(--border-subtle);
  }

  .outro-inner h2 {
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-snug);
  }

  .outro-inner p {
    color: var(--fg-secondary);
  }
</style>
