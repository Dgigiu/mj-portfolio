---
import { getCollection } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import HeroGradient from "../components/HeroGradient.astro";
import CaseStudyCard from "../components/CaseStudyCard.astro";

interface Props {
  title: string;
  summary: string;
  role: string;
  period: string;
  client: string;
  domain: string;
}

const { title, summary, role, period, client, domain } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
const currentSlug = Astro.url.pathname
  .replace(new RegExp(`^${base}work/`), "")
  .replace(/\/$/, "");

const more = (
  await getCollection("case-studies", ({ data }) => !data.draft)
)
  .filter((entry) => entry.slug !== currentSlug)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={title} description={summary}>
  <HeroGradient>
    <p class="eyebrow eyebrow-light">Case study</p>
    <h1>{title}</h1>
    <p class="summary">{summary}</p>
  </HeroGradient>

  <section class="case-meta container">
    <dl>
      <div>
        <dt>Role</dt>
        <dd>{role}</dd>
      </div>
      <div>
        <dt>Period</dt>
        <dd>{period}</dd>
      </div>
      <div>
        <dt>Client</dt>
        <dd>{client}</dd>
      </div>
      <div>
        <dt>Domain</dt>
        <dd>{domain}</dd>
      </div>
    </dl>
  </section>

  <article class="case-body container">
    <div class="prose">
      <slot />
    </div>
  </article>

  {
    more.length > 0 && (
      <section class="more container">
        <header class="more-head">
          <h2>More case studies</h2>
          <p>{more.length === 1 ? "1 other" : `${more.length} others`}</p>
        </header>
        <ul class="more-list">
          {more.map((s) => (
            <li>
              <CaseStudyCard
                href={`${base}work/${s.slug}/`}
                title={s.data.title}
                summary={s.data.summary}
                client={s.data.client}
                domain={s.data.domain}
                period={s.data.period}
                cover={s.data.cover}
                compact
              />
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>

<style>
  .summary {
    color: rgba(240, 240, 240, 0.82);
    font-size: var(--text-lg);
    margin-top: var(--space-4);
    max-width: 52ch;
  }

  .eyebrow-light {
    color: rgba(240, 240, 240, 0.7);
  }

  .case-meta {
    margin-top: var(--space-7);
    margin-bottom: var(--space-7);
  }

  .case-meta dl {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-5);
    margin: 0;
    padding: var(--space-5) 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .case-meta div {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .case-meta dt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin: 0;
  }

  .case-meta dd {
    margin: 0;
    font-size: var(--text-md);
    color: var(--text);
  }

  .case-body {
    padding-bottom: var(--space-7);
  }

  .more {
    padding: var(--space-8) 0 var(--space-7);
  }

  .more-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-top: 1px solid var(--border);
    padding-top: var(--space-7);
  }

  .more-head p {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .more-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-5);
  }
</style>
