---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import CaseStudyCard from "../components/CaseStudyCard.astro";

interface Props {
  title: string;
  summary: string;
  role: string;
  period: string;
  client: string;
  domain: string;
  cover?: ImageMetadata;
}

const { title, summary, role, period, client, domain, cover } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "") + "/";
const currentSlug = Astro.url.pathname
  .replace(new RegExp(`^${base}work/`), "")
  .replace(/\/$/, "");

const more = (
  await getCollection("case-studies", ({ data }) => !data.draft)
)
  .filter((entry) => entry.slug !== currentSlug)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={title} description={summary}>
  <header class="case-header">
    <div class="container">
      <div class="case-header-inner">
        <p class="mj-eyebrow">CASE STUDY · {client}</p>
        <h1 class="case-title">{title}</h1>
        <p class="case-summary">{summary}</p>
        <p class="case-meta">{role} · {period} · {domain}</p>
      </div>
    </div>
  </header>

  {
    cover && (
      <div class="case-cover">
        <div class="container">
          <Image
            src={cover}
            alt={`${title} project cover`}
            widths={[960, 1440, 1920]}
            sizes="(min-width: 960px) 960px, 100vw"
            class="cover-img"
          />
        </div>
      </div>
    )
  }

  <article class="case-body container">
    <div class="prose">
      <slot />
    </div>
  </article>

  {
    more.length > 0 && (
      <section class="more container">
        <header class="more-head">
          <h2>More case studies</h2>
        </header>
        <ul class="more-list">
          {more.map((s) => (
            <li>
              <CaseStudyCard
                href={`${base}work/${s.slug}/`}
                title={s.data.title}
                summary={s.data.summary}
                client={s.data.client}
                domain={s.data.domain}
                period={s.data.period}
                cover={s.data.cover}
                compact
              />
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>

<style>
  .case-header {
    padding: var(--space-16) 0 var(--space-12);
  }

  .case-header-inner {
    max-width: var(--content-prose);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .case-title {
    font-family: var(--font-sans);
    font-weight: var(--weight-semi);
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-snug);
    color: var(--fg-primary);
    margin: 0;
  }

  .case-summary {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--fg-secondary);
    margin: 0;
  }

  .case-meta {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    line-height: var(--leading-normal);
    color: var(--fg-muted);
    margin: 0;
  }

  .case-cover {
    padding-bottom: var(--space-12);
  }

  .cover-img {
    width: 100%;
    max-width: var(--content-wide);
    height: auto;
    border-radius: var(--radius-md);
    display: block;
  }

  .case-body {
    padding-bottom: var(--space-16);
  }

  .more {
    padding: var(--space-16) 0;
    border-top: var(--hairline) solid var(--border-subtle);
  }

  .more-head {
    margin-bottom: var(--space-8);
  }

  .more-head h2 {
    font-family: var(--font-sans);
    font-weight: var(--weight-semi);
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-snug);
    color: var(--fg-primary);
    margin: 0;
  }

  .more-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-8);
  }

  @media (max-width: 640px) {
    .case-title {
      font-size: var(--text-3xl);
    }
  }
</style>
